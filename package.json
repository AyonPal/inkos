{
  "name": "tattoo-studio-os",
  "version": "0.2.0",
  "description": "Booking + deposit + consent + automated aftercare for tattoo artists. Runs on Cloudflare Workers + D1.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "wrangler d1 migrations apply tattoo-studio --local",
    "db:migrate:prod": "wrangler d1 migrations apply tattoo-studio --remote"
  },
  "dependencies": {
    "hono": "^4.6.12",
    "stripe": "^17.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.93.0"
  }
}
